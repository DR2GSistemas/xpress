#!/usr/bin/env php
<?php

declare(strict_types=1);

namespace Xpress\Cli;

require_once __DIR__ . '/../vendor/autoload.php';

class XpressCli
{
    private string $basePath;
    private string $projectRoot;

    public function __construct()
    {
        $this->projectRoot = getcwd();
        $this->basePath = '/';
    }

    public function run(array $argv): int
    {
        array_shift($argv);
        $command = $argv[0] ?? 'help';

        return match ($command) {
            'htaccess' => $this->generateHtaccess($argv),
            'serve' => $this->serve($argv),
            'init' => $this->init($argv),
            'route:list' => $this->routeList($argv),
            'help' => $this->help(),
            default => $this->help("Comando desconocido: {$command}"),
        };
    }

    private function generateHtaccess(array $args): int
    {
        $options = $this->parseOptions($args, [
            'public' => false,
            'output' => false,
        ]);

        $publicPath = $options['public'] ?? ($this->projectRoot . '/public');
        $outputFile = $options['output'] ?? ($publicPath . '/.htaccess');
        $entryPoint = $options['entry'] ?? 'index.php';
        $basePath = $options['base'] ?? '/';

        if (!is_dir($publicPath)) {
            $this->error("El directorio no existe: {$publicPath}");
            return 1;
        }

        $htaccess = $this->generateHtaccessContent($basePath, $entryPoint);

        if ($outputFile === 'stdout') {
            echo $htaccess;
            return 0;
        }

        if (file_exists($outputFile) && !$this->confirm("Sobrescribir {$outputFile}?")) {
            $this->info("Operación cancelada.");
            return 0;
        }

        file_put_contents($outputFile, $htaccess);
        $this->success("✓ .htaccess generado en: {$outputFile}");

        return 0;
    }

    private function generateHtaccessContent(string $basePath, string $entryPoint): string
    {
        $basePath = rtrim($basePath, '/');
        if ($basePath === '') {
            $basePath = '/';
        }

        $basePathRule = '';
        if ($basePath !== '/') {
            $basePathRule = <<<HTACCESS
# Base path: {$basePath}
RewriteBase {$basePath}

HTACCESS;
        }

        $entryPoint = ltrim($entryPoint, '/');

        return <<<HTACCESS
# ============================================
# Xpress Router - Apache Configuration
# Generated by Xpress CLI
# ============================================

# Enable RewriteEngine
RewriteEngine On

{$basePathRule}

# Redirect to HTTPS (descomenta en producción)
# RewriteCond %{HTTPS} off
# RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# Don't rewrite requests for static files
RewriteCond %{REQUEST_URI} -f [OR]
RewriteCond %{REQUEST_URI} -d
RewriteRule ^ - [L]

# Redirect all other requests to index.php
RewriteRule ^ {$entryPoint} [QSA,L]

# Security headers
<IfModule mod_headers.c>
    Header always set X-Content-Type-Options "nosniff"
    Header always set X-Frame-Options "SAMEORIGIN"
    Header always set X-XSS-Protection "1; mode=block"
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
</IfModule>

# Prevent directory listing
Options -Indexes

# Protect sensitive files
<FilesMatch "^\.">
    Order allow,deny
    Deny from all
</FilesMatch>

# Cache static assets
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType image/jpg "access plus 1 year"
    ExpiresByType image/jpeg "access plus 1 year"
    ExpiresByType image/gif "access plus 1 year"
    ExpiresByType image/png "access plus 1 year"
    ExpiresByType image/webp "access plus 1 year"
    ExpiresByType text/css "access plus 1 month"
    ExpiresByType application/javascript "access plus 1 month"
    ExpiresByType application/json "access plus 0 seconds"
</IfModule>

# Compress text files
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html
    AddOutputFilterByType DEFLATE text/plain
    AddOutputFilterByType DEFLATE text/xml
    AddOutputFilterByType DEFLATE text/css
    AddOutputFilterByType DEFLATE application/javascript
    AddOutputFilterByType DEFLATE application/json
    AddOutputFilterByType DEFLATE application/xml
</IfModule>

# PHP settings (ajusta según necesidades)
<IfModule mod_php.c>
    php_value upload_max_filesize 10M
    php_value post_max_size 10M
    php_value max_execution_time 60
</IfModule>
HTACCESS;
    }

    private function serve(array $args): int
    {
        $options = $this->parseOptions($args, [
            'port' => false,
            'host' => false,
            'public' => false,
        ]);

        $port = (int) ($options['port'] ?? 8080);
        $host = $options['host'] ?? 'localhost';
        $publicPath = $options['public'] ?? ($this->projectRoot . '/public');
        $entryPoint = $options['entry'] ?? 'index.php';

        if (!is_dir($publicPath)) {
            $this->error("El directorio no existe: {$publicPath}");
            $this->info("Usa --public para especificar otro directorio.");
            return 1;
        }

        $entryPoint = realpath($publicPath . '/' . ltrim($entryPoint, '/'));
        if (!$entryPoint || !file_exists($entryPoint)) {
            $this->error("Archivo de entrada no encontrado: {$publicPath}/{$entryPoint}");
            return 1;
        }

        $this->info("╔══════════════════════════════════════════════════════════╗");
        $this->info("║                    Xpress Development Server              ║");
        $this->info("╠══════════════════════════════════════════════════════════╣");
        $this->info("║  URL:      http://{$host}:{$port}                          ║");
        $this->info("║  Document: {$publicPath}          ║");
        $this->info("║  Entry:    " . basename($entryPoint) . str_repeat(' ', 42 - strlen(basename($entryPoint))) . "║");
        $this->info("╠══════════════════════════════════════════════════════════╣");
        $this->info("║  Presiona Ctrl+C para detener                           ║");
        $this->info("╚══════════════════════════════════════════════════════════╝");

        $this->info("");
        $this->info("Commands for testing:");
        $this->info("  curl http://{$host}:{$port}/api/health");
        $this->info("  curl http://{$host}:{$port}/");
        $this->info("");

        chdir($publicPath);

        passthru("php -S {$host}:{$port} " . escapeshellarg($entryPoint));

        return 0;
    }

    private function init(array $args): int
    {
        $options = $this->parseOptions($args, [
            'force' => false,
        ]);

        $force = isset($options['force']) || in_array('--force', $args);

        $structure = [
            'public' => [
                '.htaccess' => fn() => $this->generateHtaccessContent('/', 'index.php'),
                'index.php' => $this->getIndexPhpTemplate(),
            ],
            'src' => [
                'Controllers' => [
                    'HomeController.php' => $this->getHomeControllerTemplate(),
                ],
                'Middleware' => [
                    'CorsMiddleware.php' => $this->getCorsMiddlewareTemplate(),
                ],
            ],
            'routes' => [
                'web.php' => $this->getRoutesTemplate(),
            ],
            'config' => [],
            'storage' => [
                'logs' => [],
                'cache' => [],
            ],
            'bootstrap.php' => $this->getBootstrapTemplate(),
            '.env.example' => $this->getEnvTemplate(),
            '.env' => $this->getEnvTemplate(),
            'composer.json' => $this->getComposerJsonTemplate(),
        ];

        $this->info("");
        $this->info("╔══════════════════════════════════════════════════════════╗");
        $this->info("║          Xpress Framework - Project Initializer          ║");
        $this->info("╚══════════════════════════════════════════════════════════╝");
        $this->info("");
        $this->info("Creating project structure...");
        $this->info("");

        $created = 0;
        $skipped = 0;

        foreach ($structure as $name => $content) {
            if (is_array($content)) {
                // It's a directory with children
                $this->createDirectory($name, $force);
                $created += $this->createStructure($name, $content, $force, $skipped);
            } elseif (is_string($content)) {
                // It's a file at root level
                $result = $this->createFile($this->projectRoot . '/' . $name, $content, $force);
                if ($result === 'created') $created++;
                elseif ($result === 'skipped') $skipped++;
            }
        }

        $this->info("");
        $this->success("✓ Project initialized successfully!");
        $this->info("");
        $this->info("Created: {$created} files/directories");
        if ($skipped > 0) {
            $this->warn("Skipped: {$skipped} (already exist)");
        }
        $this->info("");
        $this->info("Project structure:");
        $this->info("  ├── public/         # Public web root");
        $this->info("  ├── src/           # Application source");
        $this->info("  │   ├── Controllers/");
        $this->info("  │   └── Middleware/");
        $this->info("  ├── routes/        # Route definitions");
        $this->info("  ├── config/        # Configuration files");
        $this->info("  ├── storage/       # Logs and cache");
        $this->info("  ├── bootstrap.php  # Application bootstrap");
        $this->info("  └── .env           # Environment config");
        $this->info("");
        $this->info("Next steps:");
        $this->info("  1. cd {$this->projectRoot}");
        $this->info("  2. composer install");
        $this->info("  3. Edit .env with your database credentials");
        $this->info("  4. php xpress serve");
        $this->info("  5. Open http://localhost:8080");
        $this->info("");
        $this->info("Available routes:");
        $this->info("  GET /              - Home page");
        $this->info("  GET /api/health    - Health check");
        $this->info("  GET /hello/{name}  - Hello world");

        return 0;
    }

    private function createDirectory(string $path, bool $force): void
    {
        $fullPath = $this->projectRoot . '/' . $path;
        if (!is_dir($fullPath)) {
            mkdir($fullPath, 0755, true);
            $this->info("  ✓ created: {$path}/");
        } else {
            $this->info("  → exists:  {$path}/");
        }
    }

    private function createStructure(string $basePath, array $structure, bool $force, int &$skipped): int
    {
        $created = 0;
        foreach ($structure as $name => $content) {
            $fullPath = $this->projectRoot . '/' . $basePath . '/' . $name;
            
            if (is_array($content)) {
                // It's a subdirectory
                if (!is_dir($fullPath)) {
                    mkdir($fullPath, 0755, true);
                    $this->info("  ✓ created: {$basePath}/{$name}/");
                }
                $created += $this->createStructure($basePath . '/' . $name, $content, $force, $skipped);
            } elseif (is_string($content)) {
                // It's a file
                $result = $this->createFile($fullPath, $content, $force);
                if ($result === 'created') {
                    $created++;
                } elseif ($result === 'skipped') {
                    $skipped++;
                }
            } elseif (is_callable($content)) {
                $data = $content();
                $result = $this->createFile($fullPath, $data, $force);
                if ($result === 'created') {
                    $created++;
                } elseif ($result === 'skipped') {
                    $skipped++;
                }
            }
        }
        return $created;
    }

    private function createFile(string $filePath, string $content, bool $force): string
    {
        $relativePath = str_replace($this->projectRoot . '/', '', $filePath);
        
        if (file_exists($filePath) && !$force) {
            $this->warn("  ⚠ skipped: {$relativePath} (exists)");
            return 'skipped';
        }

        $dir = dirname($filePath);
        if (!is_dir($dir)) {
            mkdir($dir, 0755, true);
        }

        file_put_contents($filePath, $content);
        $this->success("  ✓ created: {$relativePath}");
        return 'created';
    }

    private function routeList(array $args): int
    {
        $options = $this->parseOptions($args, [
            'json' => false,
        ]);

        $routes = $this->discoverRoutes();

        if (empty($routes)) {
            $this->info("No se encontraron rutas.");
            return 0;
        }

        if (isset($options['json'])) {
            echo json_encode($routes, JSON_PRETTY_PRINT | JSON_UNESCAPED_UNICODE);
            return 0;
        }

        $this->info("╔══════════════════════════════════════════════════════════════════════╗");
        $this->info("║                           RUTAS REGISTRADAS                          ║");
        $this->info("╠═════════╦══════════════╦═════════════════════════════════════════════╣");

        foreach ($routes as $route) {
            $method = str_pad(implode('|', $route['methods']), 7);
            $path = str_pad($route['path'], 50);
            $handler = substr($route['handler'], 0, 30);
            printf("║ %-7s ║ %-12s ║ %-50s ║\n", $method, '', $path);
            printf("║         ║              ║ Handler: %-46s ║\n", $handler);
            $this->info("╠═════════╬══════════════╬═════════════════════════════════════════════╣");
        }

        $this->info("╚═════════╩══════════════╩═════════════════════════════════════════════╝");
        $this->info("Total: " . count($routes) . " rutas");

        return 0;
    }

    private function discoverRoutes(): array
    {
        $routes = [];

        $routesFile = $this->projectRoot . '/routes/web.php';
        if (file_exists($routesFile)) {
            $content = file_get_contents($routesFile);
            preg_match_all('/->(get|post|put|patch|delete|options|head|any)\s*\(\s*[\'"]([^\'"]+)[\'"]/i', $content, $matches, PREG_SET_ORDER);
            
            foreach ($matches as $match) {
                $method = strtoupper($match[1]);
                $path = $match[2];
                $routes[] = [
                    'methods' => $method === 'ANY' ? ['GET', 'POST', 'PUT', 'PATCH', 'DELETE'] : [$method],
                    'path' => $path,
                    'handler' => 'Closure'
                ];
            }
        }

        return $routes;
    }

    private function help(string $message = ''): int
    {
        if ($message) {
            $this->error($message);
            echo "\n";
        }

        echo <<<HELP
Xpress CLI - Router REST API para PHP 8.4

USO:
    xpress <comando> [opciones]

COMANDOS:
    htaccess [opciones]      Genera archivo .htaccess para Apache
    serve [opciones]         Inicia servidor de desarrollo
    init [opciones]          Inicializa estructura de proyecto
    route:list [opciones]    Lista rutas registradas
    help                     Muestra esta ayuda

OPCIONES DE htaccess:
    --public=<ruta>          Directorio público (default: ./public)
    --output=<archivo>       Archivo de salida (default: public/.htaccess)
    --entry=<archivo>        Archivo de entrada (default: index.php)
    --base=<ruta>            Base path (default: /)
    --stdout                 Imprime a stdout en lugar de archivo

EJEMPLOS:
    xpress htaccess                          Genera .htaccess básico
    xpress htaccess --public=htdocs         Directorio personalizado
    xpress htaccess --base=/api/v1          Con base path
    xpress htaccess --stdout                Ver contenido sin crear archivo

OPCIONES DE serve:
    --port=<puerto>          Puerto (default: 8080)
    --host=<host>            Host (default: localhost)
    --public=<ruta>          Directorio público (default: ./public)
    --entry=<archivo>        Archivo de entrada (default: index.php)

EJEMPLOS:
    xpress serve                             Inicia en localhost:8080
    xpress serve --port=3000                Puerto personalizado
    xpress serve --host=0.0.0.0             Escucha en todas las interfaces
    xpress serve --public=htdocs             Directorio personalizado

OPCIONES DE init:
    --force                    Sobrescribir archivos existentes

EJEMPLOS:
    xpress init                               Inicializa proyecto
    xpress init --force                       Reescribe todo

OPCIONES DE route:list:
    --json                      Salida en formato JSON

EJEMPLOS:
    xpress route:list                           Lista rutas formateadas
    xpress route:list --json                    Lista rutas en JSON

HELP;

        return $message ? 1 : 0;
    }

    private function parseOptions(array $args, array $defaults): array
    {
        $options = $defaults;

        foreach ($args as $arg) {
            if (str_starts_with($arg, '--')) {
                $arg = substr($arg, 2);
                
                if (str_contains($arg, '=')) {
                    [$key, $value] = explode('=', $arg, 2);
                    $options[$key] = $value;
                } else {
                    $options[$arg] = true;
                }
            }
        }

        return $options;
    }

    private function confirm(string $message): bool
    {
        echo "{$message} [s/N]: ";
        $handle = fopen("php://stdin", "r");
        $line = fgets($handle);
        fclose($handle);
        return in_array(strtolower(trim($line)), ['s', 'si', 'sí', 'y', 'yes']);
    }

    private function info(string $message): void
    {
        echo "\033[0;36m{$message}\033[0m\n";
    }

    private function success(string $message): void
    {
        echo "\033[0;32m{$message}\033[0m\n";
    }

    private function warn(string $message): void
    {
        echo "\033[0;33m{$message}\033[0m\n";
    }

    private function error(string $message): void
    {
        echo "\033[0;31mError: {$message}\033[0m\n";
    }

    private function getHomeControllerTemplate(): string
    {
        return <<<'PHP'
<?php

declare(strict_types=1);

namespace App\Controllers;

use Xpress\XRequest;
use Xpress\XResponse;
use Xpress\Attributes\{XRoute, XGroup};

#[XGroup('/api')]
class HomeController
{
    #[XRoute('/health', 'GET', name: 'health')]
    public function health(): XResponse
    {
        return (new XResponse())->json([
            'status' => 'healthy',
            'timestamp' => date('Y-m-d H:i:s'),
            'version' => '1.0.0'
        ]);
    }

    #[XRoute('/hello/{name}', 'GET', name: 'hello')]
    public function hello(XRequest $request, array $params): XResponse
    {
        $name = $params['name'] ?? 'World';
        return (new XResponse())->json([
            'message' => "Hello, {$name}!",
            'time' => date('Y-m-d H:i:s')
        ]);
    }
}
PHP;
    }

    private function getCorsMiddlewareTemplate(): string
    {
        return <<<'PHP'
<?php

declare(strict_types=1);

namespace App\Middleware;

use Xpress\XRequest;
use Xpress\XResponse;

class CorsMiddleware
{
    public function handle(XRequest $request, callable $next): XResponse
    {
        if ($request->getMethod() === 'OPTIONS') {
            return (new XResponse())
                ->withHeader('Access-Control-Allow-Origin', '*')
                ->withHeader('Access-Control-Allow-Methods', 'GET, POST, PUT, PATCH, DELETE, OPTIONS, HEAD')
                ->withHeader('Access-Control-Allow-Headers', 'Content-Type, Authorization, X-Requested-With')
                ->withHeader('Access-Control-Max-Age', '86400');
        }

        $response = $next($request);

        return $response
            ->withHeader('Access-Control-Allow-Origin', '*')
            ->withHeader('Access-Control-Allow-Methods', 'GET, POST, PUT, PATCH, DELETE, OPTIONS, HEAD')
            ->withHeader('Access-Control-Allow-Headers', 'Content-Type, Authorization, X-Requested-With');
    }
}
PHP;
    }

    private function getRoutesTemplate(): string
    {
        return <<<'PHP'
<?php

declare(strict_types=1);

use Xpress\XRouter;
use Xpress\XRequest;
use Xpress\XResponse;
use App\Controllers\HomeController;
use App\Middleware\CorsMiddleware;

/** @var XRouter $router */

// Global middleware
$router->use(CorsMiddleware::class);

// Register controllers with attributes
$router->registerControllers([HomeController::class]);

// Simple routes
$router->get('/', function (XRequest $req) {
    return (new XResponse())->json([
        'framework' => 'Xpress',
        'version' => '1.0.0',
        'status' => 'running'
    ]);
});
PHP;
    }

    private function getComposerJsonTemplate(): string
    {
        return <<<'JSON'
{
    "name": "myapp/xpress-api",
    "description": "Xpress REST API",
    "type": "project",
    "require": {
        "php": "^8.4",
        "dr2gsistemas/xpress": "^1.1"
    },
    "require-dev": {
        "pestphp/pest": "^3.0"
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "scripts": {
        "test": "pest",
        "serve": "php -S localhost:8080 -t public"
    }
}
JSON;
    }

    private function getIndexPhpTemplate(): string
    {
        return <<<'PHP'
<?php

declare(strict_types=1);

use Xpress\XRouter;

define('BASE_PATH', '/');

require_once __DIR__ . '/../vendor/autoload.php';

$router = new XRouter();

require_once __DIR__ . '/../routes/web.php';

$response = $router->dispatch();
$response->send();
PHP;
    }

    private function getBootstrapTemplate(): string
    {
        return <<<'PHP'
<?php

declare(strict_types=1);

require_once __DIR__ . '/vendor/autoload.php';

if (file_exists(__DIR__ . '/.env')) {
    $lines = file(__DIR__ . '/.env', FILE_IGNORE_NEW_LINES | FILE_SKIP_EMPTY_LINES);
    foreach ($lines as $line) {
        if (str_starts_with(trim($line), '#')) continue;
        if (!str_contains($line, '=')) continue;
        [$key, $value] = explode('=', $line, 2);
        $key = trim($key);
        $value = trim($value);
        if (!array_key_exists($key, $_ENV)) {
            $_ENV[$key] = $value;
            putenv("{$key}={$value}");
        }
    }
}

define('APP_DEBUG', filter_var($_ENV['APP_DEBUG'] ?? false, FILTER_VALIDATE_BOOLEAN));
define('APP_ENV', $_ENV['APP_ENV'] ?? 'production');
PHP;
    }

    private function getEnvTemplate(): string
    {
        return <<<'ENV'
# Environment Configuration

APP_ENV=development
APP_DEBUG=true
APP_KEY=

# Database
DB_HOST=localhost
DB_PORT=3306
DB_DATABASE=xpress
DB_USERNAME=root
DB_PASSWORD=

# Server
SERVER_HOST=localhost
SERVER_PORT=8080
ENV;
    }
}

exit((new XpressCli())->run($argv));
